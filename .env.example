# Expo reads this at bundle time. Copy to `.env` in this same folder (project root, not `backend/`).
# Then restart Metro: npx expo start --clear
#
# iOS Simulator on Mac (backend on same machine):
#   EXPO_PUBLIC_TTS_DEV_URL=http://127.0.0.1:8080
# Physical iPhone on same Wi‑Fi as PC:
#   EXPO_PUBLIC_TTS_DEV_URL=http://YOUR_PC_LAN_IP:8080  (ipconfig → Wireless IPv4)
# If Expo Go on iPhone still shows "Network request failed", the store Expo Go app ignores this
# project's ATS rules — run a dev build so app.json applies: npx expo run:ios
# Or expose TTS over HTTPS (e.g. tunnel) and point this URL there.

EXPO_PUBLIC_TTS_DEV_URL=http://192.168.1.10:8080
